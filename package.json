{
  "name": "scholar-guard-front",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:dev": "tsc && cross-env VITE_BUILD_MODE=dev vite build",
    "build:test": "tsc && cross-env VITE_BUILD_MODE=test vite build",
    "build:prod": "tsc && cross-env VITE_BUILD_MODE=prod vite build",
    "build:prod_test": "cross-env VITE_BUILD_MODE=prod vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "lint": "eslint \"src/**/*.{ts,tsx,js,jsx}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,less,md}\"",
    "lint-staged": "lint-staged",
    "commit": "cz"
  },
  "dependencies": {
    "@ant-design/charts": "^2.6.6",
    "@ant-design/icons": "^6.0.2",
    "@ant-design/plots": "^2.6.4",
    "@fingerprintjs/fingerprintjs": "^5.0.1",
    "@icon-park/react": "^1.4.2",
    "@reduxjs/toolkit": "^2.9.0",
    "ahooks": "^3.9.6",
    "antd": "^5.29.1",
    "axios": "^1.12.0",
    "dayjs": "^1.11.18",
    "echarts-for-react": "^3.0.6",
    "moment": "^2.30.1",
    "nanoid": "^5.1.6",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.8.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@eslint/js": "^9.39.1",
    "@types/eslint": "^9.6.1",
    "@types/file-saver": "^2.0.7",
    "@types/html2canvas": "^1.0.0",
    "@types/jspdf": "^2.0.0",
    "@types/node": "^22.19.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitejs/plugin-react": "^5.1.1",
    "commitizen": "^4.3.1",
    "cross-env": "^10.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-react-app": "^7.0.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "less": "^4.4.2",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "terser": "^5.37.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}

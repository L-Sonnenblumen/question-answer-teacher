# http://editorconfig.org
root = true

[*]
# 设置字符集
charset = utf-8
# 缩进风格：空格
indent_style = space
# 缩进大小：2个空格
indent_size = 2
# 换行符统一为 LF (主流跨平台规范)
end_of_line = lf
# 在文件末尾自动插入一个空行 (POSIX 标准)
insert_final_newline = true
# 删除行尾的多余空格
trim_trailing_whitespace = true

[*.md]
# Markdown 经常需要行尾空格来表示换行，所以单独关闭
trim_trailing_whitespace = false